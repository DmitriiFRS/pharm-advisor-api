generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id    Int     @default(autoincrement()) @id
  email String @unique
  password String
  name String
  phoneNumber String
  hashedRefreshToken String?
  isVerified Boolean @default(false)
  verificationToken String? @db.Text
  passwordResetToken String? @db.Text
  passwordResetExpires DateTime?
  roleId Int

  translations UserTranslation[]
  logins UserLogin[]
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model UserLogin {
  id        Int      @id @default(autoincrement())
  userId    Int
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("user_logins")
}

model Role {
  id Int @default(autoincrement()) @id
  name String @unique
  slug String @unique
  admin Boolean @default(false)
  user User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations RoleTranslation[]

  @@map("roles")
}

model Article {
  id Int @default(autoincrement()) @id
  title String
  content String @db.Text
  youtubeLink String? @db.Text
  slug String @unique
  isPublished Boolean @default(true)
  publishedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  imageId Int?
  media Media? @relation(fields: [imageId], references: [id], onDelete: SetNull)

  pdfId Int?
  pdf Media? @relation("ArticlePdf", fields: [pdfId], references: [id], onDelete: SetNull)

  translations ArticleTranslation[]

  @@map("articles")
}

model UserTranslation {
  id Int @default(autoincrement()) @id
  userId Int
  locale String
  name String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_translations")
}

model Contact {
  id Int @id @default(1) 
  email String?
  phone String?
  address String?
  telegramLink String? @db.Text
  googleMapsLink String? @db.Text
  instagramLink String? @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations ContactTranslation[]

  @@map("contacts")
}

model ContactTranslation {
  id Int @default(autoincrement()) @id
  contactId Int
  locale String
  address String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  @@unique([contactId, locale])
  @@map("contact_translations")
}

model Faq {
  id Int @default(autoincrement()) @id
  question String
  answer String @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations FaqTranslation[]

  @@map("faqs")
}

model FaqTranslation {
  id Int @default(autoincrement()) @id
  faqId Int
  locale String
  question String
  answer String @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  faq Faq @relation(fields: [faqId], references: [id], onDelete: Cascade)
  @@unique([faqId, locale])
  @@map("faq_translations")
}

model RoleTranslation {
  id Int @default(autoincrement()) @id
  roleId Int
  locale String
  name String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  @@unique([roleId, locale])
  @@map("role_translations")
}

model Lead {
  id Int @default(autoincrement()) @id
  name String?
  email String?
  phoneNumber String?
  message String? @db.Text
  page String?
  pageSection String?
  referrer String?
  ipAddress String?
  userAgent String? @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leads")
}

model Service {
  id Int @default(autoincrement()) @id
  name String
  price Int?
  label String
  description String @db.Text
  serviceFeatures Json
  imageId Int?
  media Media? @relation(fields: [imageId], references: [id], onDelete: SetNull)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations ServiceTranslation[]

  @@map("services")
}

model ServiceTranslation {
  id Int @default(autoincrement()) @id
  serviceId Int
  locale String
  name String
  label String
  description String @db.Text
  serviceFeatures Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  @@unique([serviceId, locale])
  @@map("service_translations")
}

model Media {
  id Int @default(autoincrement()) @id
  url String
  fileName String
  mimeType String
  size Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles Article[]
  articlePdf Article[] @relation("ArticlePdf")
  services Service[]

  @@map("media")
}

model ArticleTranslation {
  id Int @default(autoincrement()) @id
  articleId Int
  locale String
  title String
  content String @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  @@unique([articleId, locale])
  @@map("article_translations")
}
